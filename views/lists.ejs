<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
   <link rel="stylesheet" href="style.css">
</head>
<body>
   <%- include('navbar') %>
  <div id="list_parent">
      <h1>Task List Page</h1>

 
  <ul>
 
  <% data.forEach(element => { %>
  <div id="child">
    <li><%=element.task%></li>
 <li ><%=element.message%></li>
  <button id="update"><a href="/update?_id=<%=element._id%>">Update</a></button>
  <button id="delete"><a href="/delete?_id=<%=element._id%>">Delete</a></button>
  </div>
 <br>
<% }) %>
</ul>
 </div>
</body>
</html>